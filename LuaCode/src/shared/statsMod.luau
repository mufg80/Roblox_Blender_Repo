-- For one function only where it needs either staff or spell info
function statsMod.GetAttackSpell(spellName: string): AttackSpell?
	local attack: AttackSpell = { effectMultiplier = 0, magicType = "None", missChance = 0 }
	if statsMod.SpellInfo[spellName] then
		attack.magicType = statsMod.SpellInfo[spellName].magicType
		attack.effectMultiplier = statsMod.SpellInfo[spellName].effectMultiplier
		attack.missChance = statsMod.SpellInfo[spellName].missChance
		return attack
	end
	if statsMod.StaffStats[spellName] then
		attack.magicType = statsMod.StaffStats[spellName].magicType
		attack.effectMultiplier = statsMod.StaffStats[spellName].effectMultiplier
		attack.missChance = statsMod.StaffStats[spellName].missChance
		return attack
	end
	return nil
end

