--!strict

-- Forward declarations (enums & small reusable types)
export type MagicType = "Artificer" | "Primordial" | "Nature" | "None"

export type SpellType = "damage" | "areaDamage" | "heal" | "buff" | "debuff" | "utility"

-- FIXED: { string } is invalid → must be array type
export type SpawnableFerals = { string }

export type AttackSpell = {
	magicType: string,
	missChance: number,
	effectMultiplier: number,
}

export type PlayerHealth = {[string]:number}

export type PlayerMana = {[string]:number}

export type SpellInfo = {
	magicType: string,
	missChance: number,
	effectMultiplier: number,
	manaCost: number,
	spellType: SpellType,
	range: number,
	cooldown: number,
	numberTargets: number,
	aggro: number,
	castTime: number,
	effectTime: number,
	effectOffsetXZ: number,
	effectName: string,
	printedName: string,
	spellline: string,
	needsUnlocked: boolean,
}

export type StaffStats = {
	name: string,
	maxRange: number,
	bulletSpeed: number,
	arcHeight: number,
	bulletTrail: string,
	visualSize: number,
	visualTime: number,
	BulletTemplate: string,
	CoolDown: number?,
	coolDown: number?,
	printedName: string,
	magicType: string,
    missChance: number,
    effectMultiplier: number,
}

-- Buff / debuff modifiers
export type BuffInfo = {
	hitPoints: number?,
	attack: number?,
	attackDelay: number?,
	defense: number?,
	armour: number?,
	primordialmagicdefense: number?,
	artificermagicdefense: number?,
	naturemagicdefense: number?,
	speed: number?,
	seconds: number,
	maxDamage: number?,
}

-- Creature base stats
export type CreatureStats = {
	magicType: MagicType,
	hitPoints: number,
	attack: number,
	attackDelay: number,
	defense: number,
	armour: number,
	primordialmagicdefense: number,
	artificermagicdefense: number,
	naturemagicdefense: number,
	speed: number,
	maxDamage: number,
	distanceForAttacker: number,
	height: number,
	aggroRadius: number,
	level: number,
	width: number,
	printedName: string,
}

-- Pathfinding configuration
export type PathfindingParams = {
	AgentRadius: number,
	AgentHeight: number,
	AgentCanJump: boolean,
	WaypointSpacing: number,
	Costs: { [string]: number },
}

-- Adornee offsets
export type AdorneeOffset = { [string]: Vector3 }

-- Main exported module type
export type StatsMod = {
	MaxSpellDamage: number,
	MaxSpellCost: number,
	DELAY: number,
	MaxDamageConstant: number,
	GetAttackSpell: (spellName: string) -> AttackSpell?,
	MagicType: { [string]: MagicType },
	Colors: { [string]: string },
	AttackSpell: AttackSpell,

	MagicLevels: {
		Artificer: { [string]: { staffs: { string }, abilities: { string }, spells: { string } } },
		Primordial: { [string]: { staffs: { string }, abilities: { string }, spells: { string } } },
		Nature: { [string]: { staffs: { string }, abilities: { string }, spells: { string } } },
	},

	SpellUpgradeNames: { string },

	SpellInfo: { [string]: SpellInfo },
	BuffInfo: { [string]: BuffInfo },
	StaffStats: { [string]: StaffStats },

	creatureStats: { [string]: CreatureStats },
	creatureMana: { [string]: { MaxMana: number, Mana: number } },
	MaxCreatures: { [string]: number },
	CreatureExpWorth: { [string]: number },
	SpawnableFerals: SpawnableFerals,

	Pathing: { [string]: PathfindingParams },
	AdorneeOffset: AdorneeOffset,
	Pics: { [string]: string },

	InitStats: { [string]: { [string]: any } },

	EarnedStaffNames: { [string]: MagicType },
	playerMana:PlayerMana,
	playerHealth:PlayerHealth,
}

